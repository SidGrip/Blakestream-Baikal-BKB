From 27cfb6b6ca32a96c61f13d464750ba25ca40354c Mon Sep 17 00:00:00 2001
From: Blakestream-GaintB <sid@blakestream.local>
Date: Wed, 8 Apr 2026 23:31:01 -0500
Subject: [PATCH] driver-baikalu: dynamic poll-master so disabling miner 0
 doesn't break USB polling

---
 driver-baikalu.c | 31 ++++++++++++++++++++++++-------
 1 file changed, 24 insertions(+), 7 deletions(-)

diff --git a/driver-baikalu.c b/driver-baikalu.c
index d0d402d..4ca7e18 100644
--- a/driver-baikalu.c
+++ b/driver-baikalu.c
@@ -839,14 +839,31 @@ static int64_t baikal_scanhash(struct thr_info *thr)
         return (-1);
     }

-    if (baikal->miner_id == 0) {
-        if (baikal_process_result(baikal) != true) {
-            baikal_cleanup(baikal);
-            return (-1);
+    /* PATCH 4: Determine which miner_id should poll USB results.
+     * Originally hardcoded to 0, but if miner 0 is administratively
+     * disabled (ascdisable), sgminer suspends its thread, which would
+     * stop USB polling for everyone. Instead, the LOWEST currently-
+     * enabled miner_id polls. Also: do NOT cleanup the device on a
+     * transient process_result failure -- that nukes ALL miners. */
+    {
+        int _pm = 0, _i;
+        for (_i = 0; _i < info->miner_count; _i++) {
+            struct thr_info *_t = mining_thr[info->miners[_i].thr_id];
+            if (_t && _t->cgpu && _t->cgpu->deven != DEV_DISABLED) {
+                _pm = _i;
+                break;
+            }
+        }
+        if (baikal->miner_id == _pm) {
+            if (baikal_process_result(baikal) != true) {
+                applog(LOG_WARNING,
+                    "baikal_process_result transient failure miner %d, skipping (was: full cleanup)",
+                    baikal->miner_id);
+                return 0;
+            }
+        } else {
+            cgsleep_ms(50);
         }
-    }
-    else {
-        cgsleep_ms(50);
     }

     baikal->temp = miner->temp;
--
2.43.0
