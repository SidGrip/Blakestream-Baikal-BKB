diff --git a/algorithm/blake256.c b/algorithm/blake256.c
index b81b1fb..283c666 100644
--- a/algorithm/blake256.c
+++ b/algorithm/blake256.c
@@ -62,10 +62,18 @@ void blake256_midstate(struct work *work)
   memcpy(work->midstate, ctx_blake.H, 32);
   endian_flip32(work->midstate, work->midstate);

-  char *strdata, *strmidstate;
-  strdata = bin2hex(work->data, 80);
-  strmidstate = bin2hex(work->midstate, 32);
-  applog(LOG_DEBUG, "data %s midstate %s", strdata, strmidstate);
+  /* Blakestream-GaintB v2.1 leak fix: upstream calls bin2hex() unconditionally
+   * for a LOG_DEBUG message but never frees the result. In production
+   * (opt_debug=false) the applog is a no-op but the allocations still happen,
+   * leaking ~232 bytes per work-generation. Guard with opt_debug + free both
+   * buffers. Same bug fixed in blakecoin.c and decred.c. */
+  if (opt_debug) {
+    char *strdata = bin2hex(work->data, 80);
+    char *strmidstate = bin2hex(work->midstate, 32);
+    applog(LOG_DEBUG, "data %s midstate %s", strdata, strmidstate);
+    free(strdata);
+    free(strmidstate);
+  }
 }

 void blake256_prepare_work(dev_blk_ctx *blk, uint32_t *state, uint32_t *pdata)
