+void baikal_pin_failover(struct cgpu_info *cgpu, int pool_no)
+{
+    if (!cgpu || !baikal_pin_index_valid(cgpu->miner_id))
+        return;
+
+    mutex_lock(&baikal_pin_lock);
+    baikal_init_pin_state_locked();
+    baikal_user_failover_pins[cgpu->miner_id] = pool_no;
+    mutex_unlock(&baikal_pin_lock);
+
+    cgpu->failover_pool_no = pool_no;
+}
+
+void baikal_clear_failover_pin(struct cgpu_info *cgpu)
+{
+    if (!cgpu || !baikal_pin_index_valid(cgpu->miner_id)) {
+        if (cgpu) cgpu->failover_pool_no = BAIKAL_POOL_UNSET;
+        return;
+    }
+
+    mutex_lock(&baikal_pin_lock);
+    baikal_init_pin_state_locked();
+    baikal_user_failover_pins[cgpu->miner_id] = BAIKAL_POOL_UNSET;
+    mutex_unlock(&baikal_pin_lock);
+
+    cgpu->failover_pool_no = BAIKAL_POOL_UNSET;
+}
+
+int baikal_user_failover_pool(const struct cgpu_info *cgpu)
+{
+    return cgpu ? cgpu->failover_pool_no : BAIKAL_POOL_UNSET;
