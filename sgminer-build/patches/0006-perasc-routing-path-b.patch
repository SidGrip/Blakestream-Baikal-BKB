+/* v2 Path B: per-ASC pool routing via filtered-pop. Forward decls for the
+ * helpers that translate cgpu_info pin metadata into a target pool for the
+ * staged-work pop, plus the per-routed-pool watermark probe used by the
+ * gen_thread to avoid sleeping while a routed pool is below desired stage. */
+static bool baikal_pool_routing_active(struct cgpu_info *cgpu);
+static struct pool *baikal_effective_pool_for_cgpu(struct cgpu_info *cgpu);
+static int routed_pool_demand(struct pool *pool);
+static int total_routed_pool_demand(void);
+static struct pool *pool_with_routed_deficit_locked(int *out_deficit);
+static struct pool *pool_with_routed_deficit(int *out_deficit);
+static struct work *hash_pop_pool(struct pool *target_pool, bool blocking);
+
 int hw_errors;
 int hw_errors_bkl;
 int total_accepted, total_rejected;
@@ -6703,15 +6715,120 @@ static void pool_resus(struct pool *pool)
 
 /* If this is called non_blocking, it will return NULL for work so that must
  * be handled. */
-static struct work* hash_pop(bool blocking)
+/* v2 Path B: count items in the global staged_work queue whose work->pool
+ * matches the given pool. Caller must hold stgd_lock. Used by the gen_thread
+ * to figure out per-pool deficits without introducing per-pool queues. */
+static int staged_for_pool_locked(struct pool *target_pool)
+{
+    struct work *work, *tmp;
+    int n = 0;
+
+    if (!target_pool)
+        return (HASH_COUNT(staged_work));
+
+    HASH_ITER(hh, staged_work, work, tmp) {
+        if (work->pool == target_pool)
+            n++;
+    }
+    return (n);
+}
+
+/* v2 Path B: walk all routed pools (those with at least one cgpu pinned)
+ * and return the one with the largest deficit between routed_pool_demand
+ * and currently-staged items. NULL if no routed pool is below its desired
+ * staged count. Caller must hold stgd_lock. */
+static struct pool *pool_with_routed_deficit_locked(int *out_deficit)
 {
-    struct work *work = NULL, *tmp;
-    int hc;
+    struct pool *best = NULL;
+    int best_deficit = 0;
+    int i;
+
+    for (i = 0; i < total_pools; i++) {
+        struct pool *p = pools[i];
+        int demand;
+        int have;
+        int deficit;
+
+        demand = routed_pool_demand(p);
+        if (demand <= 0)
+            continue;
+
+        have = staged_for_pool_locked(p);
+        deficit = demand - have;
+        if (deficit > best_deficit) {
+            best = p;
+            best_deficit = deficit;
+        }
+    }
+    if (out_deficit)
+        *out_deficit = best_deficit;
+    return (best);
+}
+
+/* v2 Path B: same as the locked version but takes stgd_lock for the caller.
+ * Used in code paths that don't already hold it. */
+static struct pool *pool_with_routed_deficit(int *out_deficit)
+{
+    struct pool *p;
 
