 int thecounter = 0; // Added for debug 26.03.18
 
 static int api_clock = BAIKAL_CLK_DEF;
+static pthread_mutex_t baikal_pin_lock = PTHREAD_MUTEX_INITIALIZER;
+static bool baikal_pin_state_ready;
+static int baikal_primary_pins[BAIKAL_MAXMINERS];
+static int baikal_effective_pins[BAIKAL_MAXMINERS];
+static bool baikal_failover_pins[BAIKAL_MAXMINERS];
+
+static bool baikal_pin_index_valid(int miner_id)
+{
+    return miner_id >= 0 && miner_id < BAIKAL_MAXMINERS;
+}
+
+static void baikal_init_pin_state_locked(void)
+{
+    int i;
+
+    if (baikal_pin_state_ready)
+        return;
+
+    for (i = 0; i < BAIKAL_MAXMINERS; i++) {
+        baikal_primary_pins[i] = BAIKAL_POOL_UNSET;
+        baikal_effective_pins[i] = BAIKAL_POOL_UNSET;
+        baikal_failover_pins[i] = false;
+    }
+
+    baikal_pin_state_ready = true;
+}
+
+static void baikal_sync_pool_state(struct cgpu_info *cgpu, int primary_pool_no, int effective_pool_no, bool failover_active)
+{
+    if (!cgpu)
+        return;
+
+    cgpu->primary_pool_no = primary_pool_no;
+    cgpu->effective_pool_no = effective_pool_no;
+    cgpu->pool_failover_active = failover_active;
+}
+
+static void baikal_seed_pool_state(struct cgpu_info *cgpu)
+{
+    int primary_pool_no = BAIKAL_POOL_UNSET;
+    int effective_pool_no = BAIKAL_POOL_UNSET;
+    bool failover_active = false;
+
+    if (!cgpu || !baikal_pin_index_valid(cgpu->miner_id)) {
+        baikal_sync_pool_state(cgpu, primary_pool_no, effective_pool_no, failover_active);
+        return;
+    }
+
+    mutex_lock(&baikal_pin_lock);
+    baikal_init_pin_state_locked();
+    primary_pool_no = baikal_primary_pins[cgpu->miner_id];
+    effective_pool_no = baikal_effective_pins[cgpu->miner_id];
+    failover_active = baikal_failover_pins[cgpu->miner_id];
+    mutex_unlock(&baikal_pin_lock);
+
+    baikal_sync_pool_state(cgpu, primary_pool_no, effective_pool_no, failover_active);
+}
+
+void baikal_pin_pool(struct cgpu_info *cgpu, int pool_no)
+{
+    if (!cgpu || !baikal_pin_index_valid(cgpu->miner_id))
+        return;
+
+    mutex_lock(&baikal_pin_lock);
+    baikal_init_pin_state_locked();
+    baikal_primary_pins[cgpu->miner_id] = pool_no;
+    baikal_effective_pins[cgpu->miner_id] = pool_no;
+    baikal_failover_pins[cgpu->miner_id] = false;
+    mutex_unlock(&baikal_pin_lock);
+
+    baikal_sync_pool_state(cgpu, pool_no, pool_no, false);
+}
+
+void baikal_clear_pool_pin(struct cgpu_info *cgpu)
+{
+    if (!cgpu || !baikal_pin_index_valid(cgpu->miner_id)) {
+        baikal_sync_pool_state(cgpu, BAIKAL_POOL_UNSET, BAIKAL_POOL_UNSET, false);
+        return;
+    }
+
+    mutex_lock(&baikal_pin_lock);
+    baikal_init_pin_state_locked();
+    baikal_primary_pins[cgpu->miner_id] = BAIKAL_POOL_UNSET;
+    baikal_effective_pins[cgpu->miner_id] = BAIKAL_POOL_UNSET;
+    baikal_failover_pins[cgpu->miner_id] = false;
+    mutex_unlock(&baikal_pin_lock);
+
+    baikal_sync_pool_state(cgpu, BAIKAL_POOL_UNSET, BAIKAL_POOL_UNSET, false);
+}
+
+void baikal_set_effective_pool(struct cgpu_info *cgpu, int pool_no, bool failover_active)
+{
+    int primary_pool_no = BAIKAL_POOL_UNSET;
+
+    if (!cgpu || !baikal_pin_index_valid(cgpu->miner_id)) {
+        baikal_sync_pool_state(cgpu, primary_pool_no, pool_no, failover_active);
+        return;
+    }
+
+    mutex_lock(&baikal_pin_lock);
+    baikal_init_pin_state_locked();
+    primary_pool_no = baikal_primary_pins[cgpu->miner_id];
+    baikal_effective_pins[cgpu->miner_id] = pool_no;
+    baikal_failover_pins[cgpu->miner_id] = failover_active;
+    mutex_unlock(&baikal_pin_lock);
+
+    baikal_sync_pool_state(cgpu, primary_pool_no, pool_no, failover_active);
+}
+
+int baikal_primary_pool(const struct cgpu_info *cgpu)
+{
+    return cgpu ? cgpu->primary_pool_no : BAIKAL_POOL_UNSET;
+}
+
+int baikal_effective_pool(const struct cgpu_info *cgpu)
+{
+    return cgpu ? cgpu->effective_pool_no : BAIKAL_POOL_UNSET;
+}
+
+bool baikal_pool_failover_active(const struct cgpu_info *cgpu)
