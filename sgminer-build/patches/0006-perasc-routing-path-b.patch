+static void ascpool(struct io_data *io_data, __maybe_unused SOCKETTYPE c, char *param, bool isjson, __maybe_unused char group)
+{
+    struct cgpu_info *cgpu;
+    char pool_buf[24];
+    char *opt;
+    char *endptr;
+    long pool_no;
+    int numasc = numascs();
+    int id;
+
+    if (numasc == 0) {
+        message(io_data, MSG_ASCNON, 0, NULL, isjson);
+        return;
+    }
+
+    if (param == NULL || *param == '\0') {
+        message(io_data, MSG_MISID, 0, NULL, isjson);
+        return;
+    }
+
+    opt = strchr(param, ',');
+    if (opt)
+        *(opt++) = '\0';
+    if (!opt || !*opt) {
+        message(io_data, MSG_MISASCPOOL, 0, NULL, isjson);
+        return;
+    }
+
+    id = atoi(param);
+    if (id < 0 || id >= numasc) {
+        message(io_data, MSG_INVASC, id, NULL, isjson);
+        return;
+    }
+
+    while (isspace((unsigned char)*opt))
+        opt++;
+
+    int dev = ascdevice(id);
+    if (dev < 0) {
+        message(io_data, MSG_INVASC, id, NULL, isjson);
+        return;
+    }
+
+    cgpu = get_devices(dev);
+    if (cgpu->drv->drv_id != DRIVER_baikalu) {
+        message(io_data, MSG_ASCNOPOOL, id, NULL, isjson);
+        return;
+    }
+
+    pool_no = strtol(opt, &endptr, 10);
+    while (isspace((unsigned char)*endptr))
+        endptr++;
+    if (*opt == '\0' || *endptr != '\0') {
+        message(io_data, MSG_INVASCPOOL, 0, opt, isjson);
+        return;
+    }
+
+    if (pool_no == BAIKAL_POOL_UNSET) {
+        baikal_clear_pool_pin(cgpu);
+        message(io_data, MSG_ASCPOOLCLR, id, NULL, isjson);
+        return;
+    }
+
+    if (pool_no < 0 || pool_no >= total_pools) {
+        message(io_data, MSG_INVASCPOOL, 0, opt, isjson);
+        return;
+    }
+
+    baikal_pin_pool(cgpu, (int)pool_no);
+    snprintf(pool_buf, sizeof(pool_buf), "%ld", pool_no);
+    message(io_data, MSG_ASCPOOLSET, id, pool_buf, isjson);
+}
 #endif
 
 static void checkcommand(struct io_data *io_data, __maybe_unused SOCKETTYPE c, char *param, bool isjson, char group);
